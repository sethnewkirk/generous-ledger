filters:
  and:
    - file.inFolder("diary")
    - type == "diary"
properties:
  file.link:
    displayName: File
  date:
    displayName: Date
  tags:
    displayName: Tags
views:
  - type: table
    name: Recent Entries
    order:
      - property: date
        direction: desc
    limit: 14
  - type: table
    name: All Entries
    order:
      - property: date
        direction: desc
    limit: 30
