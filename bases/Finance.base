filters:
  and:
    - file.inFolder("data/finance")
properties:
  file.link:
    displayName: File
  week:
    displayName: Week
  period_start:
    displayName: Start
  period_end:
    displayName: End
  total_budgeted:
    displayName: Budgeted
  total_spent:
    displayName: Spent
  over_budget_categories:
    displayName: Over Budget
views:
  - type: table
    name: Budget Summaries
    order:
      - property: period_start
        direction: desc
    limit: 12
